# Strava Tell Me More - Environment Variables Template
# Copy this file to .env and fill in your actual API keys

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Strava API Configuration
# Get these from https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_strava_client_id_here
STRAVA_CLIENT_SECRET=your_strava_client_secret_here

# Strava Token Configuration
# You need either an access token OR a refresh token (refresh token is preferred)

# Option 1: Access Token (expires every 6 hours)
# Generate this through OAuth flow or use existing token
STRAVA_ACCESS_TOKEN=your_strava_access_token_here

# Option 2: Refresh Token (recommended - for automatic token renewal)
# This allows the app to automatically refresh expired access tokens
STRAVA_REFRESH_TOKEN=your_strava_refresh_token_here

# Setup Instructions:
# 1. Go to https://www.strava.com/settings/api
# 2. Create an application to get CLIENT_ID and CLIENT_SECRET
# 3. Use Strava's OAuth flow to get ACCESS_TOKEN and REFRESH_TOKEN
# 4. IMPORTANT: When authorizing, request these scopes: "read,activity:read"
# 5. For testing, you can use just ACCESS_TOKEN, but it will expire
# 6. For production use, include REFRESH_TOKEN for automatic renewal

# Quick OAuth URL Builder (replace YOUR_CLIENT_ID):
# https://www.strava.com/oauth/authorize?client_id=YOUR_CLIENT_ID&response_type=code&redirect_uri=http://localhost&approval_prompt=force&scope=read,activity:read

# Troubleshooting Token Issues:
# - If you get "401 Unauthorized" errors, your access token has expired
# - If you get "activity:read_permission missing" error, reauthorize with proper scopes
# - If you have a refresh token, the app will automatically renew it
# - If you only have access token, you'll need to manually get a new one
# - CRITICAL: Make sure your app has these scopes: "read,activity:read"
# - Without "activity:read" scope, you'll only see public profile info